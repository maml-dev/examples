    mamlText: "{\n  name: \"bin-frank\"\n  version: \"9.3.14\"\n  description: \"Terga vir talis.\"\n  license: \"GPL-3.0\"\n\n  author: \"Simon Raynor\"\n  homepage: \"https://enchanted-relative.biz\"\n  repository: \"https://github.com/Magdalena_Kertzmann10/bin-frank\"\n\n  private: false\n  type: \"module\"\n}"
