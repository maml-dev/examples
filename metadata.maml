  {
    num: "721"
    title: "Backup Strategy"
    description: "Backup schedule and retention policy."
    shapeIndex: 1
    mamlText: "{\n  source: {\n    type: \"mongodb\"\n    host: \"db.internal\"\n    databases: [\n      \"hose\"\n      \"tenant\"\n    ]\n  }\n\n  # Backup schedule\n  schedule: {\n    full: \"0 2 * * 0\" # weekly Sunday 2am\n    incremental: \"0 2 * * 1-6\" # daily except Sunday\n    snapshot: \"0 */4 * * *\" # every 4 hours\n  }\n\n  retention: {\n    daily: 13\n    weekly: 7\n    monthly: 7\n  }\n\n  destination: {\n    type: \"gcs\"\n    path: \"/mnt/backups/bookcase\"\n    encryption: true\n    compression: \"lz4\"\n  }\n}"
  }
  {
    num: "722"
    title: "Terraform Resource"
    description: "Infrastructure as code resource definition."
    shapeIndex: 1
    mamlText: "{\n  provider: \"aws\"\n  region: \"us-east-1\"\n  resources: {\n    # Network\n    vpc: {\n      cidr_block: \"10.149.0.0/16\"\n      enable_dns: true\n      tags: {\n        Name: \"thyme-vpc\"\n        Environment: \"production\"\n      }\n    }\n\n    # Compute\n    instance: {\n      ami: \"ami-47317ddc\"\n      type: \"t3.medium\"\n      key_name: \"orchid-key\"\n      monitoring: true\n      root_volume: {\n        size: 50\n        type: \"gp2\"\n        encrypted: true\n      }\n    }\n\n    # Security\n    security_group: {\n      name: \"allow-web\"\n      ingress_port: 80\n      ingress_cidr: \"0.0.0.0/0\"\n    }\n  }\n}"
  }
  {
    num: "723"
    title: "Email Routing"
    description: "Email routing and filtering rules."
    shapeIndex: 1
    mamlText: "{\n  domain: \"awesome-deduction.info\"\n  inbound: {\n    mx_records: [\n      \"mx1.awesome-deduction.info\"\n      \"mx2.awesome-deduction.info\"\n    ]\n    spam_filter: {\n      enabled: true\n      threshold: 7\n      action: \"tag\"\n    }\n\n    dkim: {\n      enabled: true\n      selector: \"default\"\n      key_size: 2048\n    }\n  }\n\n  outbound: {\n    relay: \"smtp.awesome-deduction.info\"\n    port: 587\n    tls: true\n    rate_limit: {\n      per_minute: 270\n      per_hour: 1501\n    }\n  }\n}"
  }
  {
    num: "724"
    title: "Backup Strategy"
    description: "Backup schedule and retention policy."
    shapeIndex: 1
    mamlText: "{\n  source: {\n    type: \"filesystem\"\n    host: \"localhost\"\n    databases: [\n      \"scenario\"\n      \"lay\"\n    ]\n  }\n\n  # Backup schedule\n  schedule: {\n    full: \"0 2 * * 0\" # weekly Sunday 2am\n    incremental: \"0 2 * * 1-6\" # daily except Sunday\n    snapshot: \"0 */4 * * *\" # every 4 hours\n  }\n\n  retention: {\n    daily: 12\n    weekly: 11\n    monthly: 12\n  }\n\n  destination: {\n    type: \"gcs\"\n    path: \"/mnt/backups/diversity\"\n    encryption: true\n    compression: \"gzip\"\n  }\n}"
  }
  {
    num: "725"
    title: "API Gateway"
    description: "API gateway routing and middleware configuration."
    shapeIndex: 1
    mamlText: "{\n  gateway: {\n    host: \"api.pink-sustenance.com\"\n    port: 443\n    protocol: \"https\"\n  }\n\n  # Rate limiting\n  rate_limit: {\n    enabled: true\n    window: \"5m\"\n    max_requests: 7322\n    by: \"user\"\n  }\n\n  # CORS policy\n  cors: {\n    enabled: true\n    origins: [\n      \"https://gorgeous-footrest.name\"\n      \"https://app.carefree-decision.com\"\n    ]\n    methods: [\n      \"GET\"\n      \"POST\"\n      \"PUT\"\n      \"DELETE\"\n    ]\n    max_age: 86400\n  }\n\n  cache: {\n    enabled: true\n    ttl: 746\n    store: \"memory\"\n  }\n}"
  }
  {
    num: "726"
    title: "Theme Config"
    description: "Design system theme configuration."
    shapeIndex: 1
    mamlText: "{\n  name: \"messy Theme\"\n  # Color palette\n  colors: {\n    primary: \"#abbbcb\"\n    secondary: \"#edf51c\"\n    accent: \"#52f9f4\"\n    background: \"#0d1117\"\n    text: \"#1a1a1a\"\n\n    error: \"#dc3545\"\n    warning: \"#ffc107\"\n    success: \"#28a745\"\n  }\n\n  # Typography\n  typography: {\n    font_family: \"system-ui, sans-serif\"\n    base_size: 14\n    line_height: 1.5\n    headings: {\n      font_family: \"Inter, sans-serif\"\n      weight: 700\n    }\n  }\n\n  spacing: {\n    unit: 8\n    scale: [\n      0\n      4\n      8\n      16\n      24\n      32\n      48\n    ]\n  }\n  border_radius: 6\n}"
  }
  {
