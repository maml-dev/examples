  {
    num: "433"
    title: "Backup Strategy"
    description: "Backup schedule and retention policy."
    shapeIndex: 1
    mamlText: "{\n  source: {\n    type: \"filesystem\"\n    host: \"db.internal\"\n    databases: [\n      \"forage\"\n      \"kick\"\n    ]\n  }\n\n  # Backup schedule\n  schedule: {\n    full: \"0 2 * * 0\" # weekly Sunday 2am\n    incremental: \"0 2 * * 1-6\" # daily except Sunday\n    snapshot: \"0 */4 * * *\" # every 4 hours\n  }\n\n  retention: {\n    daily: 7\n    weekly: 12\n    monthly: 15\n  }\n\n  destination: {\n    type: \"gcs\"\n    path: \"s3://backups-tusk\"\n    encryption: true\n    compression: \"lz4\"\n  }\n}"
  }
