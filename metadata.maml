  {
    num: "3039"
    title: "API Gateway"
    description: "API gateway routing and middleware configuration."
    shapeIndex: 1
    mamlText: "{\n  gateway: {\n    host: \"api.trivial-toothbrush.com\"\n    port: 8443\n    protocol: \"https\"\n  }\n\n  # Rate limiting\n  rate_limit: {\n    enabled: true\n    window: \"5m\"\n    max_requests: 7300\n    by: \"ip\"\n  }\n\n  # CORS policy\n  cors: {\n    enabled: true\n    origins: [\n      \"https://blind-plastic.net\"\n      \"https://app.pessimistic-swordfish.name\"\n    ]\n    methods: [\n      \"GET\"\n      \"POST\"\n      \"PUT\"\n      \"DELETE\"\n    ]\n    max_age: 3600\n  }\n\n  cache: {\n    enabled: false\n    ttl: 1523\n    store: \"redis\"\n  }\n}"
  }
