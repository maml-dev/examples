    description: "Design system theme configuration."
    shapeIndex: 1
    mamlText: "{\n  name: \"familiar Theme\"\n  # Color palette\n  colors: {\n    primary: \"#9b3dc2\"\n    secondary: \"#9eaabf\"\n    accent: \"#ec9c6d\"\n    background: \"#f8f9fa\"\n    text: \"#333333\"\n\n    error: \"#dc3545\"\n    warning: \"#ffc107\"\n    success: \"#28a745\"\n  }\n\n  # Typography\n  typography: {\n    font_family: \"system-ui, sans-serif\"\n    base_size: 18\n    line_height: 1.75\n    headings: {\n      font_family: \"Inter, sans-serif\"\n      weight: 700\n    }\n  }\n\n  spacing: {\n    unit: 4\n    scale: [\n      0\n      4\n      8\n      16\n      24\n      32\n      48\n    ]\n  }\n  border_radius: 8\n}"
