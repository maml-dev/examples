    shapeIndex: 1
    mamlText: "{\n  provider: \"aws\"\n  region: \"us-east-1\"\n  resources: {\n    # Network\n    vpc: {\n      cidr_block: \"10.181.0.0/16\"\n      enable_dns: true\n      tags: {\n        Name: \"bathhouse-vpc\"\n        Environment: \"production\"\n      }\n    }\n\n    # Compute\n    instance: {\n      ami: \"ami-d0bdd835\"\n      type: \"t3.micro\"\n      key_name: \"coin-key\"\n      monitoring: true\n      root_volume: {\n        size: 50\n        type: \"gp2\"\n        encrypted: true\n      }\n    }\n\n    # Security\n    security_group: {\n      name: \"allow-web\"\n      ingress_port: 22\n      ingress_cidr: \"0.0.0.0/0\"\n    }\n  }\n}"
