  {
    num: "2228"
    title: "Monitoring Config"
    description: "Application monitoring and alerting setup."
    shapeIndex: 1
    mamlText: "{\n  service: \"technologies\"\n  # Prometheus metrics\n  metrics: {\n    endpoint: \"/metrics\"\n    interval: 30 # seconds\n    labels: {\n      env: \"staging\"\n      region: \"eu-west\"\n      team: \"clothing\"\n    }\n  }\n\n  # Alert thresholds\n  alerts: {\n    cpu_threshold: 81\n    memory_threshold: 89\n    latency_p99_ms: 230\n    error_rate: 0.01\n    notification: {\n      channel: \"#oncall\"\n      severity: \"warning\"\n    }\n  }\n}"
  }
  {
