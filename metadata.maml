    shapeIndex: 3
    mamlText: "{\n  name: \"angle-hooks\"\n  secret: \"QswDRkVDBQ4ROu4QNHpJviQvM5omh4Ii\"\n  endpoints: [\n    {\n      url: \"https://intent-cow.net/webhook\"\n      events: [\n        \"create\"\n        \"update\"\n        \"delete\"\n      ]\n      active: true\n    }\n\n    {\n      url: \"https://crafty-approach.net//callback\"\n      events: [\n        \"payment.success\"\n        \"payment.failed\"\n      ]\n      active: true\n    }\n  ]\n\n  retry: {\n    max_attempts: 10\n    backoff: \"exponential\"\n    interval: 25 # seconds\n  }\n  timeout: 20 # seconds\n}"
