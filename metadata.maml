    title: "Auth Config"
    description: "Authentication and authorization settings."
    shapeIndex: 1
    mamlText: "{\n  provider: \"jwt\"\n  # Token settings\n  jwt: {\n    secret_key: \"g0oLQyFfJghTj55sMZ8srMntJxrh3EoG\"\n    algorithm: \"RS256\"\n    expiry: \"15m\"\n    refresh_expiry: \"90d\"\n  }\n\n  # OAuth provider\n  oauth: {\n    client_id: \"WeoCGRlw4soYiGWZXgs1csII\"\n    authorize_url: \"https://auth.unsightly-transom.biz/authorize\"\n    token_url: \"https://auth.motionless-season.info/token\"\n    scopes: [\n      \"openid\"\n      \"profile\"\n      \"email\"\n    ]\n  }\n\n  session: {\n    store: \"redis\"\n    cookie_name: \"sid\"\n    secure: true\n    http_only: true\n  }\n}"
