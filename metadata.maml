    mamlText: "{\n  source: {\n    type: \"postgresql\"\n    host: \"db.internal\"\n    databases: [\n      \"cantaloupe\"\n      \"legend\"\n    ]\n  }\n\n  # Backup schedule\n  schedule: {\n    full: \"0 2 * * 0\" # weekly Sunday 2am\n    incremental: \"0 2 * * 1-6\" # daily except Sunday\n    snapshot: \"0 */4 * * *\" # every 4 hours\n  }\n\n  retention: {\n    daily: 9\n    weekly: 5\n    monthly: 19\n  }\n\n  destination: {\n    type: \"sftp\"\n    path: \"s3://backups-citizen\"\n    encryption: true\n    compression: \"zstd\"\n  }\n}"
