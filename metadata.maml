    title: "Recipe"
    description: "A cooking recipe with ingredients and steps."
    shapeIndex: 3
    mamlText: "{\n  title: \"Shakshuka\"\n  servings: 7\n  prep_time: \"12 minutes\"\n  cook_time: \"24 minutes\"\n\n  # Ingredients\n  ingredients: [\n    \"2 lbs pistachio nut\"\n    \"4 oz nectarines\"\n    \"2 lbs butter beans\"\n    \"2 pieces jarrahdale pumpkin\"\n    \"1 pieces dashi\"\n    \"2 oz white wine\"\n  ]\n\n  # Instructions\n  steps: [\n    \"A fresh sun dried tomatoes creation, seasoned with kaffir leaves and sweet basil, showcasing the best of plant-based cuisine.\"\n    \"A smoky peppers creation, seasoned with arrowroot and nutmeg, showcasing the best of plant-based cuisine.\"\n    \"A robust salty stew featuring Japanese flavors, loaded with smoky meat, bitter vegetables, and a savory, golden broth.\"\n    \"A simple aubergine pie. No fancy stuff. Just pie.\"\n    \"A simple plum pie. No fancy stuff. Just pie.\"\n    \"A heartwarming Bangladeshi soup, featuring fresh rye and an aromatic blend of traditional spices.\"\n    \"Crispy fried goose bites, seasoned with sage and served with a tangy blackberry dipping sauce.\"\n  ]\n\n  nutrition: {\n    calories: 354\n    protein: \"41g\"\n    carbs: \"70g\"\n    fat: \"16g\"\n  }\n}"
  }
