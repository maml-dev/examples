    description: "Application monitoring and alerting setup."
    shapeIndex: 1
    mamlText: "{\n  service: \"e-commerce\"\n  # Prometheus metrics\n  metrics: {\n    endpoint: \"/metrics\"\n    interval: 60 # seconds\n    labels: {\n      env: \"prod\"\n      region: \"eu-west\"\n      team: \"health\"\n    }\n  }\n\n  # Alert thresholds\n  alerts: {\n    cpu_threshold: 85\n    memory_threshold: 85\n    latency_p99_ms: 1864\n    error_rate: 0.02\n    notification: {\n      channel: \"#ops-alerts\"\n      severity: \"info\"\n    }\n  }\n}"
