    shapeIndex: 4
    mamlText: "{\n  application: \"platforms\"\n  log_format: \"structured\"\n  # Example stack trace\n  sample_error: \"\"\"\nError: Use the back-end COM interface, then you can connect the solid state pixel!\n    at /usr/libdata/tinted.conf:251\n    at /mnt/mobilize_silently.png:368\n    at process.main (node:internal/main:1:1)\n\"\"\"\n\n  # Sample HTTP request\n  sample_request: \"\"\"\nGET /api/euphonium HTTP/1.1\nHost: qualified-shipper.net\nUser-Agent: Mozilla/5.0 (Macintosh; U; Intel Mac OS X 10_15_7) AppleWebKit/536.33.72 (KHTML, like Gecko) Chrome/122.3.3.9 Safari/565.8.61\nAccept: application/json\n\"\"\"\n  retention_days: 31\n}"
