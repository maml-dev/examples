    shapeIndex: 3
    mamlText: "{\n  title: \"Pasta Carbonara\"\n  servings: 8\n  prep_time: \"17 minutes\"\n  cook_time: \"113 minutes\"\n\n  # Ingredients\n  ingredients: [\n    \"1 lbs red wine\"\n    \"3 cups tom yum\"\n    \"1 tbsp limes\"\n    \"4 pieces aubergine\"\n  ]\n\n  # Instructions\n  steps: [\n    \"Baked shiitake mushrooms-stuffed chicken, seasoned with orange zest and moist herbs, accompanied by roasted rhubarb medley.\"\n    \"A slow-roasted Black-winged Stilt with a sweet, fluffy exterior. Stuffed with cumquat and covered in blackberry sauce. Sides with kale puree and wild english spinach.\"\n    \"A classic pie filled with delicious quail and tender dried chinese broccoli, baked in a delicious pastry crust and topped with a golden-brown lattice.\"\n  ]\n\n  nutrition: {\n    calories: 538\n    protein: \"44g\"\n    carbs: \"12g\"\n    fat: \"36g\"\n  }\n}"
