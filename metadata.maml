    mamlText: "{\n  app_name: \"Murphy, Ratke and Farrell\"\n  environment: \"production\"\n  debug: false\n  port: 3814\n\n  # Logging\n  log_level: \"info\"\n  log_format: \"json\"\n  api_version: \"v4\"\n  max_request_size: \"79mb\"\n}"
