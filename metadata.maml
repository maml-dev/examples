    mamlText: "{\n  title: \"Pho\"\n  servings: 7\n  prep_time: \"50 minutes\"\n  cook_time: \"31 minutes\"\n\n  # Ingredients\n  ingredients: [\n    \"2 tsp nori\"\n    \"3 cups hummus\"\n    \"2 tbsp cashews\"\n    \"3 tbsp sunflower oil\"\n    \"4 pieces nuts\"\n    \"3 tsp warehou\"\n  ]\n\n  # Instructions\n  steps: [\n    \"A special turquoise honey from Dominican Republic. To support the strong flavor it is sided with a tablespoon of methi.\"\n    \"A robust fluffy stew featuring Tatar flavors, loaded with rich meat, rich vegetables, and a salty, sour broth.\"\n    \"Hearty morwong and salmon stew, slow-cooked with anise and english spinach for a comforting, flavorful meal.\"\n    \"A succulent lamb steak, encased in a moist paprika crust, served with a side of baharat mashed potatoes.\"\n  ]\n\n  nutrition: {\n    calories: 310\n    protein: \"12g\"\n    carbs: \"40g\"\n    fat: \"36g\"\n  }\n}"
  }
