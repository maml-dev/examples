    mamlText: "{\n  trip: \"Simonisville to Cathyside\"\n  traveler: \"Pamela McGlynn\"\n  dates: {\n    departure: \"2026-04-27\"\n    return: \"2026-05-26\"\n  }\n\n  flights: [\n    {\n      flight: \"0215\"\n      from: \"MDE\"\n      to: \"CGK\"\n      departure: \"06:30\"\n      seat: \"5E\"\n    }\n\n    {\n      flight: \"0993\"\n      from: \"ARN\"\n      to: \"PPT\"\n      departure: \"20:00\"\n      seat: \"34A\"\n    }\n  ]\n\n  hotel: {\n    name: \"Rippin, O'Conner and Corkery Hotel\"\n    address: \"347 E 5th Street\"\n    check_in: \"16:00\"\n    check_out: \"12:00\"\n    confirmation: \"Y2JLLOHC\"\n  }\n}"
