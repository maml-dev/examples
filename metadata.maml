    mamlText: "# Email template configuration\n{\n  from: \"noreply@irresponsible-cruelty.com\"\n  subject: \"Beneficium curtus deludo aestus vulgus cubitum.\"\n  # HTML email body\n  template: \"\"\"\n<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"utf-8\">\n  <title>Welcome</title>\n</head>\n<body>\n  <h1>Hello, {{name}}!</h1>\n  <p>Explicabo alii curriculum deduco traho corrumpo id adeptio. Sonitus accommodo deleniti comes. Sollers nostrum theatrum vox accusator tres altus.</p>\n  <a href=\"{{url}}\">Get Started</a>\n</body>\n</html>\n\"\"\"\n\n  # Plain text fallback\n  plain_text: \"\"\"\nHello, {{name}}!\n\nValde clamo optio depereo corrumpo abundans cursim. Accedo textus crustulum consequuntur solio cado optio virgo omnis. Tredecim dedecor harum patruus utrum.\n\nVisit: {{url}}\n\"\"\"\n}"
