    mamlText: "{\n  roles: [\n    {\n      name: \"editor\"\n      permissions: [\n        \"write\"\n        \"export_data\"\n        \"view_analytics\"\n        \"manage_billing\"\n        \"read\"\n      ]\n      max_seats: null\n    }\n\n    {\n      name: \"support\"\n      permissions: [\n        \"manage_billing\"\n        \"view_analytics\"\n        \"read\"\n        \"write\"\n      ]\n      max_seats: 6\n    }\n\n    {\n      name: \"viewer\"\n      permissions: [\n        \"view_analytics\"\n        \"export_data\"\n        \"read\"\n      ]\n      max_seats: 39\n    }\n\n    {\n      name: \"viewer\"\n      permissions: [\n        \"manage_users\"\n        \"export_data\"\n      ]\n      max_seats: 15\n    }\n\n    {\n      name: \"viewer\"\n      permissions: [\n        \"write\"\n        \"manage_billing\"\n        \"export_data\"\n      ]\n      max_seats: 35\n    }\n\n    {\n      name: \"billing\"\n      permissions: [\n        \"manage_users\"\n        \"read\"\n        \"manage_billing\"\n        \"export_data\"\n        \"view_analytics\"\n      ]\n      max_seats: 24\n    }\n  ]\n}"
