  {
    num: "2237"
    title: "Queue Config"
    description: "Message queue and worker configuration."
    shapeIndex: 1
    mamlText: "{\n  broker: \"redis\"\n  connection: {\n    host: \"mq.internal\"\n    port: 6379\n    vhost: \"/staging\"\n  }\n\n  # Queue definitions\n  queues: {\n    default: {\n      concurrency: 2\n      retry: 3\n      timeout: 18794 # ms\n    }\n\n    priority: {\n      concurrency: 9\n      retry: 8\n      timeout: 9270 # ms\n    }\n  }\n\n  dead_letter: {\n    enabled: true\n    max_retries: 4\n    queue: \"dead-letter\"\n  }\n}"
  }
  {
    num: "2238"
    title: "Backup Strategy"
    description: "Backup schedule and retention policy."
    shapeIndex: 1
    mamlText: "{\n  source: {\n    type: \"mysql\"\n    host: \"db.internal\"\n    databases: [\n      \"decongestant\"\n      \"leading\"\n    ]\n  }\n\n  # Backup schedule\n  schedule: {\n    full: \"0 2 * * 0\" # weekly Sunday 2am\n    incremental: \"0 2 * * 1-6\" # daily except Sunday\n    snapshot: \"0 */4 * * *\" # every 4 hours\n  }\n\n  retention: {\n    daily: 11\n    weekly: 8\n    monthly: 8\n  }\n\n  destination: {\n    type: \"s3\"\n    path: \"s3://backups-pension\"\n    encryption: true\n    compression: \"zstd\"\n  }\n}"
  }
