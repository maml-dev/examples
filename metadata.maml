    title: "Email Routing"
    description: "Email routing and filtering rules."
    shapeIndex: 1
    mamlText: "{\n  domain: \"dental-transparency.info\"\n  inbound: {\n    mx_records: [\n      \"mx1.dental-transparency.info\"\n      \"mx2.dental-transparency.info\"\n    ]\n    spam_filter: {\n      enabled: true\n      threshold: 5\n      action: \"tag\"\n    }\n\n    dkim: {\n      enabled: true\n      selector: \"default\"\n      key_size: 1024\n    }\n  }\n\n  outbound: {\n    relay: \"smtp.dental-transparency.info\"\n    port: 25\n    tls: true\n    rate_limit: {\n      per_minute: 287\n      per_hour: 1957\n    }\n  }\n}"
