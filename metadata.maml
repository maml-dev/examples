    mamlText: "{\n  sprint: \"Sprint 1\"\n  tasks: [\n    {\n      id: \"UGGCUJ\"\n      title: \"connecting the bus won't do anything, we need to input the virtual SMTP application!\"\n      assignee: \"Granville Franecki\"\n      priority: \"medium\"\n      status: \"todo\"\n      points: 13\n    }\n\n    {\n      id: \"F2HC8K\"\n      title: \"If we connect the pixel, we can get to the CLI sensor through the digital SMTP sensor!\"\n      assignee: \"Liza Windler I\"\n      priority: \"low\"\n      status: \"done\"\n      points: 1\n    }\n\n    {\n      id: \"JDTZL5\"\n      title: \"We need to calculate the optical HEX bus!\"\n      assignee: \"Paxton Dietrich\"\n      priority: \"medium\"\n      status: \"in_progress\"\n      points: 5\n    }\n\n    {\n      id: \"IQZELQ\"\n      title: \"I'll copy the virtual VGA microchip, that should feed the XSS bandwidth!\"\n      assignee: \"Micheal Blanda MD\"\n      priority: \"medium\"\n      status: \"todo\"\n      points: 2\n    }\n\n    {\n      id: \"8TSB8M\"\n      title: \"If we copy the interface, we can get to the DNS pixel through the virtual CLI hard drive!\"\n      assignee: \"Amir Predovic\"\n      priority: \"medium\"\n      status: \"in_progress\"\n      points: 1\n    }\n\n    {\n      id: \"0HA4KC\"\n      title: \"Try to calculate the RAM pixel, maybe it will parse the primary alarm!\"\n      assignee: \"Janelle Collier\"\n      priority: \"critical\"\n      status: \"done\"\n      points: 1\n    }\n  ]\n}"
