    mamlText: "{\n  provider: \"oauth2\"\n  # Token settings\n  jwt: {\n    secret_key: \"lDAnzKNFkAjefyRN1ZLG3xwbaV1Tz7vN\"\n    algorithm: \"HS256\"\n    expiry: \"15m\"\n    refresh_expiry: \"90d\"\n  }\n\n  # OAuth provider\n  oauth: {\n    client_id: \"VAAoZlJDX0qqmoudTbHEDdcV\"\n    authorize_url: \"https://auth.burly-e-mail.name/authorize\"\n    token_url: \"https://auth.strong-vista.net/token\"\n    scopes: [\n      \"openid\"\n      \"profile\"\n      \"email\"\n    ]\n  }\n\n  session: {\n    store: \"database\"\n    cookie_name: \"sid\"\n    secure: true\n    http_only: true\n  }\n}"
