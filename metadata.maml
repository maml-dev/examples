    shapeIndex: 1
    mamlText: "{\n  source: {\n    type: \"mysql\"\n    host: \"primary.db.internal\"\n    databases: [\n      \"status\"\n      \"ownership\"\n    ]\n  }\n\n  # Backup schedule\n  schedule: {\n    full: \"0 2 * * 0\" # weekly Sunday 2am\n    incremental: \"0 2 * * 1-6\" # daily except Sunday\n    snapshot: \"0 */4 * * *\" # every 4 hours\n  }\n\n  retention: {\n    daily: 10\n    weekly: 11\n    monthly: 23\n  }\n\n  destination: {\n    type: \"s3\"\n    path: \"s3://backups-flight\"\n    encryption: true\n    compression: \"zstd\"\n  }\n}"
