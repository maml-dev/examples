    mamlText: "{\n  title: \"Som Tam\"\n  servings: 3\n  prep_time: \"58 minutes\"\n  cook_time: \"118 minutes\"\n\n  # Ingredients\n  ingredients: [\n    \"1 oz rye\"\n    \"4 oz cornmeal\"\n    \"3 lbs allspice\"\n  ]\n\n  # Instructions\n  steps: [\n    \"Baked flathead-stuffed chicken, seasoned with aniseed and crunchy herbs, accompanied by roasted cauliflower medley.\"\n    \"Our rich pigeon, slow-cooked to perfection, accompanied by steamed peas and a rich, savory gravy.\"\n    \"An exquisite pigeon roast, infused with the essence of butternut pumpkin, slow-roasted to bring out its natural flavors and served with a side of creamy dried chinese broccoli\"\n    \"A classic pie filled with delicious ostrich and sour pecorino, baked in a crunchy pastry crust and topped with a golden-brown lattice.\"\n    \"A classic pie filled with delicious salmon and crispy parrotfish, baked in a salty pastry crust and topped with a golden-brown lattice.\"\n    \"A heartwarming Sri Lankan soup, featuring fresh kenchur and an aromatic blend of traditional spices.\"\n  ]\n\n  nutrition: {\n    calories: 654\n    protein: \"44g\"\n    carbs: \"16g\"\n    fat: \"37g\"\n  }\n}"
  }
