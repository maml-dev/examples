    mamlText: "{\n  provider: \"oauth2\"\n  # Token settings\n  jwt: {\n    secret_key: \"hHGp2A5HPngjfZE4TMXgQgHA79Actk3A\"\n    algorithm: \"HS256\"\n    expiry: \"24h\"\n    refresh_expiry: \"90d\"\n  }\n\n  # OAuth provider\n  oauth: {\n    client_id: \"V2oBVp7LPkIEO3XIsPqy1TF8\"\n    authorize_url: \"https://auth.neighboring-joy.info/authorize\"\n    token_url: \"https://auth.noxious-summer.info/token\"\n    scopes: [\n      \"openid\"\n      \"profile\"\n      \"email\"\n    ]\n  }\n\n  session: {\n    store: \"database\"\n    cookie_name: \"sid\"\n    secure: true\n    http_only: true\n  }\n}"
