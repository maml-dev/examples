  {
    num: "063"
    title: "Recipe"
    description: "A cooking recipe with ingredients and steps."
    shapeIndex: 3
    mamlText: "{\n  title: \"Ebiten Maki\"\n  servings: 2\n  prep_time: \"19 minutes\"\n  cook_time: \"86 minutes\"\n\n  # Ingredients\n  ingredients: [\n    \"4 pieces capers\"\n    \"2 tbsp quark\"\n    \"3 lbs almonds\"\n  ]\n\n  # Instructions\n  steps: [\n    \"A simple mangosteen pie. No fancy stuff. Just pie.\"\n    \"Tender salmon skewers, glazed with a sweet and tangy date sauce, served over a bed of fragrant jasmine rice.\"\n    \"A special silver licorice from Azerbaijan. To support the strong flavor it is sided with a tablespoon of chilli.\"\n    \"A heartwarming Georgian soup, featuring fresh bamboo shoots and an aromatic blend of traditional spices.\"\n    \"83-day aged turkey steak, with choice of 2 sides.\"\n    \"A classic pie filled with delicious crocodile and tangy tofu, baked in a juicy pastry crust and topped with a golden-brown lattice.\"\n    \"A robust tender stew featuring Assyrian flavors, loaded with fresh meat, creamy vegetables, and a delicious, juicy broth.\"\n  ]\n\n  nutrition: {\n    calories: 491\n    protein: \"50g\"\n    carbs: \"71g\"\n    fat: \"39g\"\n  }\n}"
  }
  {
    num: "064"
    title: "App Manifest"
    description: "Full application manifest with metadata, dependencies, and scripts."
    shapeIndex: 3
    mamlText: "{\n  name: \"privilege-tentacle\"\n  version: \"2.2.20\"\n  description: \"Streamlined global encryption\"\n\n  keywords: [\n    \"expense\"\n    \"consistency\"\n    \"sparkling\"\n  ]\n\n  scripts: {\n    dev: \"node server.js --watch\"\n    build: \"tsc && esbuild src/index.ts --bundle --outfile=dist/index.js\"\n    test: \"jest\"\n    lint: \"biome check\"\n  }\n  engines: {\n    node: \">=22\"\n  }\n\n  author: {\n    name: \"Shelley Mante\"\n    email: \"Eloy.Becker@gmail.com\"\n    url: \"https://eminent-blossom.org/\"\n  }\n}"
  }
  {
    num: "065"
    title: "Recipe"
    description: "A cooking recipe with ingredients and steps."
    shapeIndex: 3
    mamlText: "{\n  title: \"Carrot Salad\"\n  servings: 6\n  prep_time: \"20 minutes\"\n  cook_time: \"58 minutes\"\n\n  # Ingredients\n  ingredients: [\n    \"4 tbsp soba\"\n    \"3 lbs onion\"\n    \"3 tbsp crabs\"\n    \"1 cups tahini\"\n    \"4 cups french eschallots\"\n  ]\n\n  # Instructions\n  steps: [\n    \"A succulent goose steak, encased in a smoky rosemary crust, served with a side of anise star mashed eggplant.\"\n    \"61-day aged venison steak, with choice of 3 sides.\"\n    \"Juicy lamb, grilled to your liking and drizzled with a bold galangal sauce, served alongside roasted sun dried tomatoes.\"\n    \"A classic pie filled with delicious rabbit and sour apple cider vinegar, baked in a fluffy pastry crust and topped with a golden-brown lattice.\"\n    \"A classic pie filled with delicious rabbit and savory tea oil, baked in a crunchy pastry crust and topped with a golden-brown lattice.\"\n  ]\n\n  nutrition: {\n    calories: 400\n    protein: \"10g\"\n    carbs: \"89g\"\n    fat: \"30g\"\n  }\n}"
