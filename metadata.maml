    mamlText: "{\n  source: {\n    type: \"mysql\"\n    host: \"db.internal\"\n    databases: [\n      \"sediment\"\n      \"runway\"\n    ]\n  }\n\n  # Backup schedule\n  schedule: {\n    full: \"0 2 * * 0\" # weekly Sunday 2am\n    incremental: \"0 2 * * 1-6\" # daily except Sunday\n    snapshot: \"0 */4 * * *\" # every 4 hours\n  }\n\n  retention: {\n    daily: 10\n    weekly: 5\n    monthly: 10\n  }\n\n  destination: {\n    type: \"gcs\"\n    path: \"/mnt/backups/cycle\"\n    encryption: true\n    compression: \"lz4\"\n  }\n}"
