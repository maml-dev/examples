    mamlText: "{\n  source: {\n    type: \"mysql\"\n    host: \"localhost\"\n    databases: [\n      \"summer\"\n      \"unit\"\n    ]\n  }\n\n  # Backup schedule\n  schedule: {\n    full: \"0 2 * * 0\" # weekly Sunday 2am\n    incremental: \"0 2 * * 1-6\" # daily except Sunday\n    snapshot: \"0 */4 * * *\" # every 4 hours\n  }\n\n  retention: {\n    daily: 14\n    weekly: 6\n    monthly: 6\n  }\n\n  destination: {\n    type: \"gcs\"\n    path: \"s3://backups-angle\"\n    encryption: true\n    compression: \"zstd\"\n  }\n}"
