    mamlText: "{\n  domain: \"bowed-climb.name\"\n  inbound: {\n    mx_records: [\n      \"mx1.bowed-climb.name\"\n      \"mx2.bowed-climb.name\"\n    ]\n    spam_filter: {\n      enabled: true\n      threshold: 5\n      action: \"reject\"\n    }\n\n    dkim: {\n      enabled: true\n      selector: \"default\"\n      key_size: 1024\n    }\n  }\n\n  outbound: {\n    relay: \"smtp.bowed-climb.name\"\n    port: 25\n    tls: true\n    rate_limit: {\n      per_minute: 347\n      per_hour: 3859\n    }\n  }\n}"
