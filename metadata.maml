    title: "Cloud Deploy Config"
    description: "Cloud deployment infrastructure configuration."
    shapeIndex: 1
    mamlText: "{\n  provider: \"aws\"\n  region: \"ap-southeast-1\"\n\n  # Compute resources\n  compute: {\n    instance_type: \"e2-standard-4\"\n    count: 6\n    auto_scaling: {\n      enabled: true\n      min: 1\n      max: 15\n      target_cpu: 79\n    }\n  }\n\n  storage: {\n    type: \"hdd\"\n    size_gb: 174\n    encrypted: true\n  }\n\n  networking: {\n    vpc: \"vpc-fefa86c9\"\n    subnet: \"10.45.0.0/16\"\n    public_ip: false\n  }\n}"
  }
  {
