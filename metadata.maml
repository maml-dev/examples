    mamlText: "{\n  provider: \"gcp\"\n  region: \"us-east-1\"\n\n  # Compute resources\n  compute: {\n    instance_type: \"e2-standard-4\"\n    count: 5\n    auto_scaling: {\n      enabled: true\n      min: 3\n      max: 13\n      target_cpu: 51\n    }\n  }\n\n  storage: {\n    type: \"ssd\"\n    size_gb: 373\n    encrypted: true\n  }\n\n  networking: {\n    vpc: \"vpc-fadf481d\"\n    subnet: \"10.195.0.0/16\"\n    public_ip: false\n  }\n}"
