  {
    num: "035"
    title: "Monitoring Config"
    description: "Application monitoring and alerting setup."
    shapeIndex: 1
    mamlText: "{\n  service: \"applications\"\n  # Prometheus metrics\n  metrics: {\n    endpoint: \"/metrics\"\n    interval: 60 # seconds\n    labels: {\n      env: \"staging\"\n      region: \"ap-south\"\n      team: \"automotive\"\n    }\n  }\n\n  # Alert thresholds\n  alerts: {\n    cpu_threshold: 93\n    memory_threshold: 90\n    latency_p99_ms: 485\n    error_rate: 0.01\n    notification: {\n      channel: \"#oncall\"\n      severity: \"info\"\n    }\n  }\n}"
  }
  {
    num: "036"
    title: "Email Routing"
    description: "Email routing and filtering rules."
    shapeIndex: 1
    mamlText: "{\n  domain: \"other-seal.biz\"\n  inbound: {\n    mx_records: [\n      \"mx1.other-seal.biz\"\n      \"mx2.other-seal.biz\"\n    ]\n    spam_filter: {\n      enabled: true\n      threshold: 7\n      action: \"reject\"\n    }\n\n    dkim: {\n      enabled: true\n      selector: \"default\"\n      key_size: 2048\n    }\n  }\n\n  outbound: {\n    relay: \"smtp.other-seal.biz\"\n    port: 465\n    tls: true\n    rate_limit: {\n      per_minute: 200\n      per_hour: 9069\n    }\n  }\n}"
  }
  {
    num: "037"
    title: "CI Pipeline"
    description: "Continuous integration pipeline definition."
    shapeIndex: 1
    mamlText: "{\n  name: \"Build & Test\"\n  trigger: {\n    branches: [\n      \"main\"\n      \"develop\"\n    ]\n    paths: [\n      \"src/**\"\n      \"tests/**\"\n    ]\n  }\n\n  stages: {\n    # Code quality\n    lint: {\n      image: \"node:22\"\n      command: \"npx biome check\"\n    }\n    test: {\n      image: \"node:22\"\n      command: \"npm test\"\n      coverage: true\n    }\n    build: {\n      image: \"node:22\"\n      command: \"npm run build\"\n      artifacts: [\n        \"dist/**\"\n        \"build/**\"\n      ]\n    }\n  }\n}"
  }
