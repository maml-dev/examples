  {
    num: "3222"
    title: "GraphQL Schema"
    description: "GraphQL type and resolver configuration."
    shapeIndex: 1
    mamlText: "{\n  schema: {\n    query: \"Query\"\n    mutation: \"Mutation\"\n  }\n\n  types: {\n    # User type\n    User: {\n      fields: {\n        id: \"ID!\"\n        name: \"String!\"\n        email: \"String!\"\n        avatar: \"String\"\n        posts: \"[Post!]!\"\n        role: \"Role!\"\n      }\n    }\n\n    # Post type\n    Post: {\n      fields: {\n        id: \"ID!\"\n        title: \"String!\"\n        body: \"String!\"\n        author: \"User!\"\n        published: \"Boolean!\"\n        created_at: \"DateTime!\"\n      }\n    }\n  }\n\n  resolvers: {\n    cache: true\n    max_depth: 5\n    max_complexity: 248\n  }\n}"
  }
  {
    num: "3223"
    title: "API Gateway"
    description: "API gateway routing and middleware configuration."
    shapeIndex: 1
    mamlText: "{\n  gateway: {\n    host: \"api.new-object.biz\"\n    port: 8443\n    protocol: \"https\"\n  }\n\n  # Rate limiting\n  rate_limit: {\n    enabled: true\n    window: \"1m\"\n    max_requests: 3382\n    by: \"api_key\"\n  }\n\n  # CORS policy\n  cors: {\n    enabled: true\n    origins: [\n      \"https://self-assured-asset.info\"\n      \"https://app.formal-intellect.com\"\n    ]\n    methods: [\n      \"GET\"\n      \"POST\"\n      \"PUT\"\n      \"DELETE\"\n    ]\n    max_age: 7200\n  }\n\n  cache: {\n    enabled: true\n    ttl: 2581\n    store: \"redis\"\n  }\n}"
  }
  {
    num: "3224"
    title: "Queue Config"
    description: "Message queue and worker configuration."
    shapeIndex: 1
    mamlText: "{\n  broker: \"sqs\"\n  connection: {\n    host: \"localhost\"\n    port: 6379\n    vhost: \"/production\"\n  }\n\n  # Queue definitions\n  queues: {\n    default: {\n      concurrency: 2\n      retry: 3\n      timeout: 27653 # ms\n    }\n\n    priority: {\n      concurrency: 9\n      retry: 7\n      timeout: 7749 # ms\n    }\n  }\n\n  dead_letter: {\n    enabled: true\n    max_retries: 10\n    queue: \"dead-letter\"\n  }\n}"
  }
  {
    num: "3225"
    title: "Monitoring Config"
    description: "Application monitoring and alerting setup."
    shapeIndex: 1
    mamlText: "{\n  service: \"functionalities\"\n  # Prometheus metrics\n  metrics: {\n    endpoint: \"/metrics\"\n    interval: 10 # seconds\n    labels: {\n      env: \"staging\"\n      region: \"ap-south\"\n      team: \"grocery\"\n    }\n  }\n\n  # Alert thresholds\n  alerts: {\n    cpu_threshold: 95\n    memory_threshold: 91\n    latency_p99_ms: 813\n    error_rate: 0.02\n    notification: {\n      channel: \"#ops-alerts\"\n      severity: \"critical\"\n    }\n  }\n}"
  }
  {
