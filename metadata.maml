    mamlText: "# Email template configuration\n{\n  from: \"noreply@unfortunate-guide.com\"\n  subject: \"Caute thesis adopto numquam.\"\n  # HTML email body\n  template: \"\"\"\n<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"utf-8\">\n  <title>Welcome</title>\n</head>\n<body>\n  <h1>Hello, {{name}}!</h1>\n  <p>Stips tantum cunae. Vulgus concedo denique accusator ullus cultellus carcer crur capto. Deserunt tres sustineo dapifer strues omnis quam uredo quisquam supellex.</p>\n  <a href=\"{{url}}\">Get Started</a>\n</body>\n</html>\n\"\"\"\n\n  # Plain text fallback\n  plain_text: \"\"\"\nHello, {{name}}!\n\nApud maxime ultra esse cura ciminatio umbra arca. Arto capio decumbo communis tamen. Reprehenderit supra illo demergo amissio bos cavus terra.\n\nVisit: {{url}}\n\"\"\"\n}"
