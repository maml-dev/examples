  {
    num: "2536"
    title: "Backup Strategy"
    description: "Backup schedule and retention policy."
    shapeIndex: 1
    mamlText: "{\n  source: {\n    type: \"filesystem\"\n    host: \"localhost\"\n    databases: [\n      \"honesty\"\n      \"marksman\"\n    ]\n  }\n\n  # Backup schedule\n  schedule: {\n    full: \"0 2 * * 0\" # weekly Sunday 2am\n    incremental: \"0 2 * * 1-6\" # daily except Sunday\n    snapshot: \"0 */4 * * *\" # every 4 hours\n  }\n\n  retention: {\n    daily: 14\n    weekly: 7\n    monthly: 20\n  }\n\n  destination: {\n    type: \"sftp\"\n    path: \"/mnt/backups/yarmulke\"\n    encryption: true\n    compression: \"gzip\"\n  }\n}"
  }
  {
    num: "2537"
    title: "Auth Config"
    description: "Authentication and authorization settings."
    shapeIndex: 1
    mamlText: "{\n  provider: \"saml\"\n  # Token settings\n  jwt: {\n    secret_key: \"pkdZNyEAKi3fFkEfaVvzmP2GJmBjgkhW\"\n    algorithm: \"HS256\"\n    expiry: \"7d\"\n    refresh_expiry: \"7d\"\n  }\n\n  # OAuth provider\n  oauth: {\n    client_id: \"C0IAux3LeEOTu2NPdUkeO6Ok\"\n    authorize_url: \"https://auth.velvety-hornet.net/authorize\"\n    token_url: \"https://auth.muffled-skean.net/token\"\n    scopes: [\n      \"openid\"\n      \"profile\"\n      \"email\"\n    ]\n  }\n\n  session: {\n    store: \"memory\"\n    cookie_name: \"sid\"\n    secure: true\n    http_only: true\n  }\n}"
  }
  {
    num: "2538"
    title: "API Gateway"
    description: "API gateway routing and middleware configuration."
    shapeIndex: 1
    mamlText: "{\n  gateway: {\n    host: \"api.impure-pinstripe.net\"\n    port: 8443\n    protocol: \"https\"\n  }\n\n  # Rate limiting\n  rate_limit: {\n    enabled: true\n    window: \"1m\"\n    max_requests: 7978\n    by: \"ip\"\n  }\n\n  # CORS policy\n  cors: {\n    enabled: true\n    origins: [\n      \"https://pricey-subsidy.name\"\n      \"https://app.perfumed-label.net\"\n    ]\n    methods: [\n      \"GET\"\n      \"POST\"\n      \"PUT\"\n      \"DELETE\"\n    ]\n    max_age: 86400\n  }\n\n  cache: {\n    enabled: true\n    ttl: 162\n    store: \"redis\"\n  }\n}"
  }
  {
    num: "2539"
    title: "Terraform Resource"
    description: "Infrastructure as code resource definition."
    shapeIndex: 1
    mamlText: "{\n  provider: \"azurerm\"\n  region: \"us-east-1\"\n  resources: {\n    # Network\n    vpc: {\n      cidr_block: \"10.123.0.0/16\"\n      enable_dns: true\n      tags: {\n        Name: \"guacamole-vpc\"\n        Environment: \"production\"\n      }\n    }\n\n    # Compute\n    instance: {\n      ami: \"ami-ef75bb77\"\n      type: \"m5.large\"\n      key_name: \"climb-key\"\n      monitoring: true\n      root_volume: {\n        size: 100\n        type: \"io1\"\n        encrypted: true\n      }\n    }\n\n    # Security\n    security_group: {\n      name: \"allow-web\"\n      ingress_port: 443\n      ingress_cidr: \"0.0.0.0/0\"\n    }\n  }\n}"
  }
  {
    num: "2540"
    title: "K8s Deployment"
    description: "Kubernetes deployment specification."
    shapeIndex: 1
    mamlText: "{\n  apiVersion: \"apps/v1\"\n  kind: \"Deployment\"\n  metadata: {\n    name: \"flat-web\"\n    namespace: \"production\"\n    labels: {\n      app: \"desk\"\n      tier: \"data\"\n    }\n  }\n\n  # Deployment spec\n  spec: {\n    replicas: 4\n    container: {\n      image: \"summary:6.10.9\"\n      port: 8080\n      resources: {\n        cpu_limit: \"250m\"\n        memory_limit: \"256Mi\"\n      }\n    }\n\n    health_check: {\n      path: \"/health\"\n      interval: 30\n      timeout: 5\n    }\n  }\n}"
  }
  {
    num: "2541"
    title: "Keyboard Shortcuts"
    description: "Editor keyboard shortcut bindings."
    shapeIndex: 2
    mamlText: "{\n  editor: \"vscode\"\n  shortcuts: [\n    {\n      key: \"Ctrl+`\"\n      action: \"save\"\n      when: \"global\"\n    }\n\n    {\n      key: \"Alt+F7\"\n      action: \"toggle_comment\"\n      when: \"global\"\n    }\n\n    {\n      key: \"F5\"\n      action: \"search_project\"\n      when: \"editor\"\n    }\n\n    {\n      key: \"Alt+Up\"\n      action: \"debug_run\"\n      when: \"editor\"\n    }\n  ]\n}"
  }
  {
    num: "2542"
    title: "Sprint Board"
    description: "Agile sprint task board."
    shapeIndex: 2
    mamlText: "{\n  sprint: \"Sprint 46\"\n  tasks: [\n    {\n      id: \"UQ4OM2\"\n      title: \"The JBOD feed is down, hack the 1080p program so we can reboot the RSS port!\"\n      assignee: \"Connie Weber-Reynolds\"\n      priority: \"high\"\n      status: \"todo\"\n      points: 8\n    }\n\n    {\n      id: \"RM8FPJ\"\n      title: \"Use the optical GB bandwidth, then you can copy the neural capacitor!\"\n      assignee: \"Dr. Reinhold Kovacek-Kertzmann\"\n      priority: \"high\"\n      status: \"review\"\n      points: 8\n    }\n\n    {\n      id: \"RLOTHQ\"\n      title: \"I'll index the optical GB capacitor, that should microchip the VGA feed!\"\n      assignee: \"Lorna Grady\"\n      priority: \"medium\"\n      status: \"todo\"\n      points: 2\n    }\n\n    {\n      id: \"TQKMCY\"\n      title: \"The UTF8 array is down, input the back-end alarm so we can parse the ASCII matrix!\"\n      assignee: \"Joyce Pfannerstill\"\n      priority: \"medium\"\n      status: \"review\"\n      points: 13\n    }\n  ]\n}"
  }
  {
    num: "2543"
    title: "Sprint Board"
    description: "Agile sprint task board."
    shapeIndex: 2
    mamlText: "{\n  sprint: \"Sprint 39\"\n  tasks: [\n    {\n      id: \"Q60NX8\"\n      title: \"If we calculate the feed, we can get to the AGP system through the auxiliary XML alarm!\"\n      assignee: \"Trace Bartoletti\"\n      priority: \"low\"\n      status: \"in_progress\"\n      points: 1\n    }\n\n    {\n      id: \"STP3KI\"\n      title: \"I'll hack the multi-byte API application, that should circuit the TLS microchip!\"\n      assignee: \"Penelope Vandervort\"\n      priority: \"medium\"\n      status: \"todo\"\n      points: 8\n    }\n\n    {\n      id: \"8IL3LV\"\n      title: \"We need to synthesize the cross-platform SCSI bandwidth!\"\n      assignee: \"Ignatius Homenick\"\n      priority: \"critical\"\n      status: \"todo\"\n      points: 3\n    }\n  ]\n}"
  }
