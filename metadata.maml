    title: "Recipe"
    description: "A cooking recipe with ingredients and steps."
    shapeIndex: 3
    mamlText: "{\n  title: \"Lemon Pie\"\n  servings: 8\n  prep_time: \"27 minutes\"\n  cook_time: \"17 minutes\"\n\n  # Ingredients\n  ingredients: [\n    \"2 pieces smoked trout\"\n    \"4 lbs bran\"\n    \"1 oz cinnamon\"\n    \"3 pieces red pepper\"\n    \"4 cups kecap manis\"\n  ]\n\n  # Instructions\n  steps: [\n    \"Juicy ostrich, grilled to your liking and drizzled with a bold cloves sauce, served alongside roasted kale.\"\n    \"A classic pie filled with delicious pigeon and moist wheat, baked in a fluffy pastry crust and topped with a golden-brown lattice.\"\n    \"Fresh kangaroo with a pinch of pot marjoram, topped by a caramelized cumquat with whipped cream\"\n    \"An exquisite chicken roast, infused with the essence of passionfruit, slow-roasted to bring out its natural flavors and served with a side of creamy bean shoots\"\n    \"A classic pie filled with delicious ostrich and bitter chickory, baked in a delicious pastry crust and topped with a golden-brown lattice.\"\n    \"Hearty crabs and duck stew, slow-cooked with sweet basil and sun dried tomatoes for a comforting, flavorful meal.\"\n  ]\n\n  nutrition: {\n    calories: 239\n    protein: \"9g\"\n    carbs: \"80g\"\n    fat: \"34g\"\n  }\n}"
  }
