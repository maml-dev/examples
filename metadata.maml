    description: "Search engine index configuration."
    shapeIndex: 1
    mamlText: "{\n  engine: \"meilisearch\"\n  connection: {\n    host: \"search.internal:7700\"\n    api_key: \"TsaWjwpDkMO8raNhc1ng5uKm8mbHLwkq\"\n    timeout: 7334\n  }\n\n  # Index settings\n  index: {\n    name: \"adviser\"\n    primary_key: \"id\"\n    searchable: [\n      \"title\"\n      \"description\"\n      \"content\"\n    ]\n    filterable: [\n      \"category\"\n      \"status\"\n      \"date\"\n    ]\n    sortable: [\n      \"date\"\n      \"relevance\"\n    ]\n  }\n\n  synonyms: {\n    js: [\n      \"javascript\"\n      \"ecmascript\"\n    ]\n    ts: [\n      \"typescript\"\n    ]\n  }\n}"
