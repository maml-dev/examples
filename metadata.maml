  {
    num: "3321"
    title: "Backup Strategy"
    description: "Backup schedule and retention policy."
    shapeIndex: 1
    mamlText: "{\n  source: {\n    type: \"mongodb\"\n    host: \"primary.db.internal\"\n    databases: [\n      \"waterspout\"\n      \"possession\"\n    ]\n  }\n\n  # Backup schedule\n  schedule: {\n    full: \"0 2 * * 0\" # weekly Sunday 2am\n    incremental: \"0 2 * * 1-6\" # daily except Sunday\n    snapshot: \"0 */4 * * *\" # every 4 hours\n  }\n\n  retention: {\n    daily: 12\n    weekly: 8\n    monthly: 18\n  }\n\n  destination: {\n    type: \"s3\"\n    path: \"s3://backups-nerve\"\n    encryption: true\n    compression: \"gzip\"\n  }\n}"
  }
  {
    num: "3322"
    title: "Backup Strategy"
    description: "Backup schedule and retention policy."
    shapeIndex: 1
    mamlText: "{\n  source: {\n    type: \"filesystem\"\n    host: \"primary.db.internal\"\n    databases: [\n      \"substitution\"\n      \"pecan\"\n    ]\n  }\n\n  # Backup schedule\n  schedule: {\n    full: \"0 2 * * 0\" # weekly Sunday 2am\n    incremental: \"0 2 * * 1-6\" # daily except Sunday\n    snapshot: \"0 */4 * * *\" # every 4 hours\n  }\n\n  retention: {\n    daily: 12\n    weekly: 12\n    monthly: 13\n  }\n\n  destination: {\n    type: \"s3\"\n    path: \"/mnt/backups/precedent\"\n    encryption: true\n    compression: \"zstd\"\n  }\n}"
  }
  {
    num: "3323"
    title: "Monitoring Config"
    description: "Application monitoring and alerting setup."
    shapeIndex: 1
    mamlText: "{\n  service: \"partnerships\"\n  # Prometheus metrics\n  metrics: {\n    endpoint: \"/metrics\"\n    interval: 10 # seconds\n    labels: {\n      env: \"staging\"\n      region: \"us-east\"\n      team: \"beauty\"\n    }\n  }\n\n  # Alert thresholds\n  alerts: {\n    cpu_threshold: 79\n    memory_threshold: 75\n    latency_p99_ms: 1543\n    error_rate: 0.01\n    notification: {\n      channel: \"#oncall\"\n      severity: \"critical\"\n    }\n  }\n}"
  }
  {
    num: "3324"
    title: "API Gateway"
    description: "API gateway routing and middleware configuration."
    shapeIndex: 1
    mamlText: "{\n  gateway: {\n    host: \"api.tired-hutch.info\"\n    port: 443\n    protocol: \"https\"\n  }\n\n  # Rate limiting\n  rate_limit: {\n    enabled: true\n    window: \"1m\"\n    max_requests: 300\n    by: \"api_key\"\n  }\n\n  # CORS policy\n  cors: {\n    enabled: true\n    origins: [\n      \"https://hurtful-requirement.com\"\n      \"https://app.familiar-hamburger.info\"\n    ]\n    methods: [\n      \"GET\"\n      \"POST\"\n      \"PUT\"\n      \"DELETE\"\n    ]\n    max_age: 86400\n  }\n\n  cache: {\n    enabled: false\n    ttl: 2267\n    store: \"memory\"\n  }\n}"
  }
  {
    num: "3325"
    title: "Cloud Deploy Config"
    description: "Cloud deployment infrastructure configuration."
    shapeIndex: 1
    mamlText: "{\n  provider: \"gcp\"\n  region: \"us-west-2\"\n\n  # Compute resources\n  compute: {\n    instance_type: \"Standard_B2s\"\n    count: 8\n    auto_scaling: {\n      enabled: true\n      min: 3\n      max: 16\n      target_cpu: 60\n    }\n  }\n\n  storage: {\n    type: \"hdd\"\n    size_gb: 295\n    encrypted: true\n  }\n\n  networking: {\n    vpc: \"vpc-e2b6bd5f\"\n    subnet: \"10.46.0.0/16\"\n    public_ip: false\n  }\n}"
  }
  {
    num: "3326"
    title: "Monitoring Config"
    description: "Application monitoring and alerting setup."
    shapeIndex: 1
    mamlText: "{\n  service: \"communities\"\n  # Prometheus metrics\n  metrics: {\n    endpoint: \"/metrics\"\n    interval: 10 # seconds\n    labels: {\n      env: \"prod\"\n      region: \"eu-west\"\n      team: \"garden\"\n    }\n  }\n\n  # Alert thresholds\n  alerts: {\n    cpu_threshold: 72\n    memory_threshold: 81\n    latency_p99_ms: 178\n    error_rate: 0.01\n    notification: {\n      channel: \"#oncall\"\n      severity: \"info\"\n    }\n  }\n}"
  }
