    title: "Terraform Resource"
    description: "Infrastructure as code resource definition."
    shapeIndex: 1
    mamlText: "{\n  provider: \"azurerm\"\n  region: \"us-east-1\"\n  resources: {\n    # Network\n    vpc: {\n      cidr_block: \"10.54.0.0/16\"\n      enable_dns: true\n      tags: {\n        Name: \"castanet-vpc\"\n        Environment: \"staging\"\n      }\n    }\n\n    # Compute\n    instance: {\n      ami: \"ami-ef4f0e5e\"\n      type: \"t3.medium\"\n      key_name: \"collaboration-key\"\n      monitoring: true\n      root_volume: {\n        size: 100\n        type: \"gp3\"\n        encrypted: true\n      }\n    }\n\n    # Security\n    security_group: {\n      name: \"allow-all\"\n      ingress_port: 8080\n      ingress_cidr: \"0.0.0.0/0\"\n    }\n  }\n}"
  }
