    mamlText: "{\n  domain: \"eminent-tabletop.org\"\n  inbound: {\n    mx_records: [\n      \"mx1.eminent-tabletop.org\"\n      \"mx2.eminent-tabletop.org\"\n    ]\n    spam_filter: {\n      enabled: true\n      threshold: 7\n      action: \"reject\"\n    }\n\n    dkim: {\n      enabled: true\n      selector: \"default\"\n      key_size: 2048\n    }\n  }\n\n  outbound: {\n    relay: \"smtp.eminent-tabletop.org\"\n    port: 25\n    tls: true\n    rate_limit: {\n      per_minute: 310\n      per_hour: 4617\n    }\n  }\n}"
