  {
    num: "1732"
    title: "Backup Strategy"
    description: "Backup schedule and retention policy."
    shapeIndex: 1
    mamlText: "{\n  source: {\n    type: \"filesystem\"\n    host: \"localhost\"\n    databases: [\n      \"aircraft\"\n      \"hyena\"\n    ]\n  }\n\n  # Backup schedule\n  schedule: {\n    full: \"0 2 * * 0\" # weekly Sunday 2am\n    incremental: \"0 2 * * 1-6\" # daily except Sunday\n    snapshot: \"0 */4 * * *\" # every 4 hours\n  }\n\n  retention: {\n    daily: 10\n    weekly: 7\n    monthly: 16\n  }\n\n  destination: {\n    type: \"sftp\"\n    path: \"s3://backups-bookcase\"\n    encryption: true\n    compression: \"zstd\"\n  }\n}"
  }
  {
