    mamlText: "{\n  title: \"Solus odit adduco desino colligo quod thorax.\"\n  slug: \"admoveo-assentator-vorax\"\n  author: {\n    name: \"Destiny Bartell\"\n    avatar: \"https://cdn.jsdelivr.net/gh/faker-js/assets-person-portrait/female/512/75.jpg\"\n    bio: \"creator\"\n  }\n  date: \"2026-04-14\"\n  tags: [\n    \"electronics\"\n    \"invite\"\n    \"cook\"\n  ]\n\n  published: false\n  reading_time: \"15 min\"\n  summary: \"Nostrum administratio magnam harum enim. Minus modi abeo autus derideo tyrannus coruscus spiculum voluptates cupiditate. Tunc capillus sursum admoneo terror utilis corroboro apud verus solium.\"\n}"
