    title: "Theme Config"
    description: "Design system theme configuration."
    shapeIndex: 1
    mamlText: "{\n  name: \"untimely Theme\"\n  # Color palette\n  colors: {\n    primary: \"#dbbd0c\"\n    secondary: \"#b39dbf\"\n    accent: \"#ceedd2\"\n    background: \"#ffffff\"\n    text: \"#e6edf3\"\n\n    error: \"#dc3545\"\n    warning: \"#ffc107\"\n    success: \"#28a745\"\n  }\n\n  # Typography\n  typography: {\n    font_family: \"system-ui, sans-serif\"\n    base_size: 16\n    line_height: 1.6\n    headings: {\n      font_family: \"\\\"Playfair Display\\\", serif\"\n      weight: 800\n    }\n  }\n\n  spacing: {\n    unit: 4\n    scale: [\n      0\n      4\n      8\n      16\n      24\n      32\n      48\n    ]\n  }\n  border_radius: 6\n}"
