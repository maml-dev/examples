  {
    num: "1679"
    title: "Recipe"
    description: "A cooking recipe with ingredients and steps."
    shapeIndex: 3
    mamlText: "{\n  title: \"Tangelo-infused Rabbit Roast\"\n  servings: 4\n  prep_time: \"16 minutes\"\n  cook_time: \"72 minutes\"\n\n  # Ingredients\n  ingredients: [\n    \"4 oz cumin\"\n    \"4 tsp arborio rice\"\n    \"4 tbsp mustard seed\"\n    \"4 cups kudzu\"\n  ]\n\n  # Instructions\n  steps: [\n    \"A classic pie filled with delicious rabbit and moist cornmeal, baked in a crispy pastry crust and topped with a golden-brown lattice.\"\n    \"A robust moist stew featuring Ainu flavors, loaded with delicious meat, sweet vegetables, and a tangy, moist broth.\"\n    \"A robust salty stew featuring Georgian flavors, loaded with sour meat, crunchy vegetables, and a sweet, tender broth.\"\n    \"Our zesty lamb, slow-cooked to perfection, accompanied by steamed garlic and a rich, savory gravy.\"\n    \"Three rice noodles with eggplant, asian greens, kohlrabi, peppers and garam masala. With a side of baked lychee, and your choice of peas or dried chinese broccoli.\"\n    \"A bitter dried chinese broccoli creation, seasoned with curry and baharat, showcasing the best of plant-based cuisine.\"\n    \"An exquisite duck roast, infused with the essence of papaw, slow-roasted to bring out its natural flavors and served with a side of creamy english spinach\"\n  ]\n\n  nutrition: {\n    calories: 687\n    protein: \"50g\"\n    carbs: \"47g\"\n    fat: \"27g\"\n  }\n}"
  }
