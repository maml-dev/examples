  {
    num: "2783"
    title: "Git Hooks"
    description: "Git hook scripts for pre-commit and pre-push."
    shapeIndex: 4
    mamlText: "# Git hooks configuration\n{\n  # Runs before each commit\n  pre-commit: \"\"\"\n#!/bin/sh\nset -e\n\n# Run linter\nnpx eslint --fix .\n\n# Run type check\nnpx tsc --noEmit\n\n# Stage fixed files\ngit add -u\n\"\"\"\n\n  # Runs before push to remote\n  pre-push: \"\"\"\n#!/bin/sh\nset -e\n\n# Run full test suite\nnpm test\n\n# Check for console.log\nif grep -rn \"console\\.log\" src/; then\n  echo \"Error: console.log found\"\n  exit 1\nfi\n\"\"\"\n\n  # Validate commit message format\n  commit-msg: \"\"\"\n#!/bin/sh\n# Enforce conventional commit format\nif ! head -1 \"$1\" | grep -qE \"^(feat|fix|docs|style|refactor|test|chore)(\\(.+\\))?: .+\"; then\n  echo \"Error: Invalid commit message format\"\n  echo \"Use: type(scope): description\"\n  exit 1\nfi\n\"\"\"\n}"
  }
  {
    num: "2784"
    title: "HTML Templates"
    description: "Email HTML templates with raw string content."
    shapeIndex: 4
    mamlText: "# Email template configuration\n{\n  from: \"noreply@innocent-flat.biz\"\n  subject: \"Textilis vomer veritatis vindico.\"\n  # HTML email body\n  template: \"\"\"\n<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"utf-8\">\n  <title>Welcome</title>\n</head>\n<body>\n  <h1>Hello, {{name}}!</h1>\n  <p>Pauci magni contigo patria qui decor. Confido curiositas absorbeo administratio trepide. Capio quidem utor.</p>\n  <a href=\"{{url}}\">Get Started</a>\n</body>\n</html>\n\"\"\"\n\n  # Plain text fallback\n  plain_text: \"\"\"\nHello, {{name}}!\n\nSummisse deduco somniculosus vesper. Video thermae tum demens carus communis creptio. Aureus ait expedita turba adsuesco adamo synagoga.\n\nVisit: {{url}}\n\"\"\"\n}"
