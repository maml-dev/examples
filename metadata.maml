  {
    num: "624"
    title: "Backup Strategy"
    description: "Backup schedule and retention policy."
    shapeIndex: 1
    mamlText: "{\n  source: {\n    type: \"filesystem\"\n    host: \"primary.db.internal\"\n    databases: [\n      \"pear\"\n      \"follower\"\n    ]\n  }\n\n  # Backup schedule\n  schedule: {\n    full: \"0 2 * * 0\" # weekly Sunday 2am\n    incremental: \"0 2 * * 1-6\" # daily except Sunday\n    snapshot: \"0 */4 * * *\" # every 4 hours\n  }\n\n  retention: {\n    daily: 8\n    weekly: 11\n    monthly: 18\n  }\n\n  destination: {\n    type: \"sftp\"\n    path: \"s3://backups-overheard\"\n    encryption: true\n    compression: \"lz4\"\n  }\n}"
  }
