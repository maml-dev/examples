  {
    num: "061"
    title: "Recipe"
    description: "A cooking recipe with ingredients and steps."
    shapeIndex: 3
    mamlText: "{\n  title: \"Tender Kangaroo With Chinese Cabbage\"\n  servings: 3\n  prep_time: \"52 minutes\"\n  cook_time: \"54 minutes\"\n\n  # Ingredients\n  ingredients: [\n    \"4 cups white bread\"\n    \"3 pieces jarrahdale pumpkin\"\n    \"4 tsp sesame oil\"\n    \"3 tbsp rye bread\"\n    \"1 cups bean shoots\"\n    \"4 cups beef stock\"\n  ]\n\n  # Instructions\n  steps: [\n    \"Tenderly braised ostrich in a rich allspice and green beans sauce, served with a side of creamy brussels sprouts.\"\n    \"Fresh soymilk with a pinch of cinnamon, topped by a caramelized custard apple with whipped cream\"\n    \"Fresh spinach with a pinch of chillies, topped by a caramelized blackberry with whipped cream\"\n    \"Tender salmon skewers, glazed with a sweet and tangy elderberry sauce, served over a bed of fragrant jasmine rice.\"\n    \"Grilled turkey kebabs, marinated in American spices and served with a fresh peppers and goji berry salad.\"\n    \"Tender rabbit skewers, glazed with a sweet and tangy lychee sauce, served over a bed of fragrant jasmine rice.\"\n  ]\n\n  nutrition: {\n    calories: 481\n    protein: \"49g\"\n    carbs: \"69g\"\n    fat: \"19g\"\n  }\n}"
  }
  {
    num: "062"
    title: "Resume"
    description: "A personal resume with experience and skills."
    shapeIndex: 3
    mamlText: "{\n  name: \"Mr. Jimmie Rowe\"\n  title: \"Human Web Supervisor\"\n  email: \"Krystal76@hotmail.com\"\n  location: \"Bahringerworth, Bouvet Island\"\n  summary: \"abacus fan, film lover 🚌\"\n\n  skills: [\n    \"Git\"\n    \"JavaScript\"\n    \"Linux\"\n    \"Rust\"\n  ]\n\n  experience: [\n    {\n      company: \"Mertz, Bogan and Dietrich\"\n      role: \"Human Factors Engineer\"\n      period: \"2021 - Present\"\n      highlights: [\n        \"Esse compello contego defetiscor asper ratione apto unde tamdiu conforto.\"\n        \"Valetudo suggero caute tepidus vindico cohors color doloremque.\"\n      ]\n    }\n\n    {\n      company: \"Zieme Inc\"\n      role: \"District Paradigm Supervisor\"\n      period: \"2020 - 2022\"\n      highlights: [\n        \"Amor supplanto volo tabesco astrum veniam vacuus adulescens.\"\n        \"Earum arbustum deleniti.\"\n      ]\n    }\n  ]\n\n  education: {\n    degree: \"PhD Computer Science\"\n    university: \"Bartoletti Group University\"\n    year: 2014\n  }\n}"
