  {
    num: "1021"
    title: "K8s Deployment"
    description: "Kubernetes deployment specification."
    shapeIndex: 1
    mamlText: "{\n  apiVersion: \"apps/v1\"\n  kind: \"Deployment\"\n  metadata: {\n    name: \"redesign-web\"\n    namespace: \"default\"\n    labels: {\n      app: \"mousse\"\n      tier: \"backend\"\n    }\n  }\n\n  # Deployment spec\n  spec: {\n    replicas: 5\n    container: {\n      image: \"pick:4.0.12\"\n      port: 8080\n      resources: {\n        cpu_limit: \"1000m\"\n        memory_limit: \"512Mi\"\n      }\n    }\n\n    health_check: {\n      path: \"/ready\"\n      interval: 15\n      timeout: 10\n    }\n  }\n}"
  }
  {
    num: "1022"
    title: "Search Config"
    description: "Search engine index configuration."
    shapeIndex: 1
    mamlText: "{\n  engine: \"typesense\"\n  connection: {\n    host: \"search.internal:9200\"\n    api_key: \"OqkpkmDPCyICiiQlefShKYCY4XzsCxoS\"\n    timeout: 8189\n  }\n\n  # Index settings\n  index: {\n    name: \"eggplant\"\n    primary_key: \"id\"\n    searchable: [\n      \"title\"\n      \"description\"\n      \"content\"\n    ]\n    filterable: [\n      \"category\"\n      \"status\"\n      \"date\"\n    ]\n    sortable: [\n      \"date\"\n      \"relevance\"\n    ]\n  }\n\n  synonyms: {\n    js: [\n      \"javascript\"\n      \"ecmascript\"\n    ]\n    ts: [\n      \"typescript\"\n    ]\n  }\n}"
  }
