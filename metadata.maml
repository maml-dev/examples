  {
    num: "1041"
    title: "Sprint Board"
    description: "Agile sprint task board."
    shapeIndex: 2
    mamlText: "{\n  sprint: \"Sprint 28\"\n  tasks: [\n    {\n      id: \"QCEUBR\"\n      title: \"compressing the port won't do anything, we need to back up the open-source AGP pixel!\"\n      assignee: \"Doreen Bruen\"\n      priority: \"high\"\n      status: \"todo\"\n      points: 3\n    }\n\n    {\n      id: \"NHRTUE\"\n      title: \"You can't override the circuit without indexing the back-end JBOD program!\"\n      assignee: \"Harry Kling IV\"\n      priority: \"low\"\n      status: \"todo\"\n      points: 3\n    }\n\n    {\n      id: \"CDCKHZ\"\n      title: \"I'll transmit the online SAS sensor, that should card the HDD driver!\"\n      assignee: \"Dylan Pfeffer\"\n      priority: \"low\"\n      status: \"review\"\n      points: 13\n    }\n\n    {\n      id: \"S629RW\"\n      title: \"Use the online JSON panel, then you can compress the mobile pixel!\"\n      assignee: \"Sierra Wiegand\"\n      priority: \"critical\"\n      status: \"done\"\n      points: 8\n    }\n\n    {\n      id: \"3EIDVZ\"\n      title: \"You can't input the driver without quantifying the neural SSD transmitter!\"\n      assignee: \"Christie Orn I\"\n      priority: \"high\"\n      status: \"review\"\n      points: 5\n    }\n\n    {\n      id: \"T2UT3D\"\n      title: \"If we input the sensor, we can get to the DNS hard drive through the digital THX interface!\"\n      assignee: \"Lee Ferry\"\n      priority: \"critical\"\n      status: \"in_progress\"\n      points: 5\n    }\n  ]\n}"
  }
