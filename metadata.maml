    title: "Linter Config"
    description: "Code linter rule configuration."
    shapeIndex: 0
    mamlText: "{\n  parser: \"espree\"\n  env: \"es2024\"\n  indent: 4\n  semicolons: false\n  quotes: \"double\"\n\n  # Formatting\n  max_line_length: 120\n  trailing_comma: \"none\"\n  no_unused_vars: true # error\n  no_console: true # warn\n}"
