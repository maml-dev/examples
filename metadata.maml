    title: "Cloud Deploy Config"
    description: "Cloud deployment infrastructure configuration."
    shapeIndex: 1
    mamlText: "{\n  provider: \"azure\"\n  region: \"us-west-2\"\n\n  # Compute resources\n  compute: {\n    instance_type: \"e2-standard-4\"\n    count: 10\n    auto_scaling: {\n      enabled: true\n      min: 1\n      max: 15\n      target_cpu: 60\n    }\n  }\n\n  storage: {\n    type: \"hdd\"\n    size_gb: 421\n    encrypted: true\n  }\n\n  networking: {\n    vpc: \"vpc-a1fddfd4\"\n    subnet: \"10.93.0.0/16\"\n    public_ip: false\n  }\n}"
