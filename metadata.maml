  {
    num: "021"
    title: "GraphQL Schema"
    description: "GraphQL type and resolver configuration."
    shapeIndex: 1
    mamlText: "{\n  schema: {\n    query: \"Query\"\n    mutation: \"Mutation\"\n  }\n\n  types: {\n    # User type\n    User: {\n      fields: {\n        id: \"ID!\"\n        name: \"String!\"\n        email: \"String!\"\n        avatar: \"String\"\n        posts: \"[Post!]!\"\n        role: \"Role!\"\n      }\n    }\n\n    # Post type\n    Post: {\n      fields: {\n        id: \"ID!\"\n        title: \"String!\"\n        body: \"String!\"\n        author: \"User!\"\n        published: \"Boolean!\"\n        created_at: \"DateTime!\"\n      }\n    }\n  }\n\n  resolvers: {\n    cache: true\n    max_depth: 15\n    max_complexity: 459\n  }\n}"
  }
  {
    num: "022"
    title: "Theme Config"
    description: "Design system theme configuration."
    shapeIndex: 1
    mamlText: "{\n  name: \"reckless Theme\"\n  # Color palette\n  colors: {\n    primary: \"#2bafe7\"\n    secondary: \"#dc413c\"\n    accent: \"#ecacc3\"\n    background: \"#f8f9fa\"\n    text: \"#333333\"\n\n    error: \"#dc3545\"\n    warning: \"#ffc107\"\n    success: \"#28a745\"\n  }\n\n  # Typography\n  typography: {\n    font_family: \"\\\"JetBrains Mono\\\", monospace\"\n    base_size: 16\n    line_height: 1.5\n    headings: {\n      font_family: \"\\\"Playfair Display\\\", serif\"\n      weight: 800\n    }\n  }\n\n  spacing: {\n    unit: 4\n    scale: [\n      0\n      4\n      8\n      16\n      24\n      32\n      48\n    ]\n  }\n  border_radius: 4\n}"
  }
  {
    num: "023"
    title: "Auth Config"
    description: "Authentication and authorization settings."
    shapeIndex: 1
    mamlText: "{\n  provider: \"oauth2\"\n  # Token settings\n  jwt: {\n    secret_key: \"LNOr7lszHZbFWJgZtTcG5RB28zqHilYj\"\n    algorithm: \"ES256\"\n    expiry: \"1h\"\n    refresh_expiry: \"30d\"\n  }\n\n  # OAuth provider\n  oauth: {\n    client_id: \"osMlDfCFAfjIImVq1yFyZgUg\"\n    authorize_url: \"https://auth.lone-pomelo.name/authorize\"\n    token_url: \"https://auth.brilliant-gallery.biz/token\"\n    scopes: [\n      \"openid\"\n      \"profile\"\n      \"email\"\n    ]\n  }\n\n  session: {\n    store: \"redis\"\n    cookie_name: \"sid\"\n    secure: true\n    http_only: true\n  }\n}"
  }
  {
    num: "024"
    title: "Email Routing"
    description: "Email routing and filtering rules."
    shapeIndex: 1
    mamlText: "{\n  domain: \"considerate-lace.biz\"\n  inbound: {\n    mx_records: [\n      \"mx1.considerate-lace.biz\"\n      \"mx2.considerate-lace.biz\"\n    ]\n    spam_filter: {\n      enabled: true\n      threshold: 8.5\n      action: \"tag\"\n    }\n\n    dkim: {\n      enabled: true\n      selector: \"default\"\n      key_size: 2048\n    }\n  }\n\n  outbound: {\n    relay: \"smtp.considerate-lace.biz\"\n    port: 25\n    tls: true\n    rate_limit: {\n      per_minute: 371\n      per_hour: 2929\n    }\n  }\n}"
  }
  {
    num: "025"
    title: "Queue Config"
    description: "Message queue and worker configuration."
    shapeIndex: 1
    mamlText: "{\n  broker: \"sqs\"\n  connection: {\n    host: \"localhost\"\n    port: 6379\n    vhost: \"/\"\n  }\n\n  # Queue definitions\n  queues: {\n    default: {\n      concurrency: 7\n      retry: 5\n      timeout: 49044 # ms\n    }\n\n    priority: {\n      concurrency: 16\n      retry: 7\n      timeout: 2890 # ms\n    }\n  }\n\n  dead_letter: {\n    enabled: true\n    max_retries: 4\n    queue: \"dead-letter\"\n  }\n}"
  }
  {
    num: "026"
    title: "Search Config"
    description: "Search engine index configuration."
    shapeIndex: 1
    mamlText: "{\n  engine: \"algolia\"\n  connection: {\n    host: \"localhost:9200\"\n    api_key: \"lobUOhxePDxh7vpUZ6Gd9Xf5dG0rxg6a\"\n    timeout: 6613\n  }\n\n  # Index settings\n  index: {\n    name: \"maintainer\"\n    primary_key: \"id\"\n    searchable: [\n      \"title\"\n      \"description\"\n      \"content\"\n    ]\n    filterable: [\n      \"category\"\n      \"status\"\n      \"date\"\n    ]\n    sortable: [\n      \"date\"\n      \"relevance\"\n    ]\n  }\n\n  synonyms: {\n    js: [\n      \"javascript\"\n      \"ecmascript\"\n    ]\n    ts: [\n      \"typescript\"\n    ]\n  }\n}"
  }
  {
    num: "027"
    title: "Backup Strategy"
    description: "Backup schedule and retention policy."
    shapeIndex: 1
    mamlText: "{\n  source: {\n    type: \"postgresql\"\n    host: \"localhost\"\n    databases: [\n      \"integer\"\n      \"saw\"\n    ]\n  }\n\n  # Backup schedule\n  schedule: {\n    full: \"0 2 * * 0\" # weekly Sunday 2am\n    incremental: \"0 2 * * 1-6\" # daily except Sunday\n    snapshot: \"0 */4 * * *\" # every 4 hours\n  }\n\n  retention: {\n    daily: 9\n    weekly: 7\n    monthly: 12\n  }\n\n  destination: {\n    type: \"s3\"\n    path: \"s3://backups-retrospectivity\"\n    encryption: true\n    compression: \"gzip\"\n  }\n}"
  }
  {
    num: "028"
    title: "GraphQL Schema"
    description: "GraphQL type and resolver configuration."
    shapeIndex: 1
    mamlText: "{\n  schema: {\n    query: \"Query\"\n    mutation: \"Mutation\"\n  }\n\n  types: {\n    # User type\n    User: {\n      fields: {\n        id: \"ID!\"\n        name: \"String!\"\n        email: \"String!\"\n        avatar: \"String\"\n        posts: \"[Post!]!\"\n        role: \"Role!\"\n      }\n    }\n\n    # Post type\n    Post: {\n      fields: {\n        id: \"ID!\"\n        title: \"String!\"\n        body: \"String!\"\n        author: \"User!\"\n        published: \"Boolean!\"\n        created_at: \"DateTime!\"\n      }\n    }\n  }\n\n  resolvers: {\n    cache: true\n    max_depth: 14\n    max_complexity: 915\n  }\n}"
  }
  {
    num: "029"
    title: "K8s Deployment"
    description: "Kubernetes deployment specification."
    shapeIndex: 1
    mamlText: "{\n  apiVersion: \"apps/v1\"\n  kind: \"Deployment\"\n  metadata: {\n    name: \"blight-worker\"\n    namespace: \"staging\"\n    labels: {\n      app: \"footrest\"\n      tier: \"data\"\n    }\n  }\n\n  # Deployment spec\n  spec: {\n    replicas: 5\n    container: {\n      image: \"birdbath:2.20.19\"\n      port: 8080\n      resources: {\n        cpu_limit: \"500m\"\n        memory_limit: \"256Mi\"\n      }\n    }\n\n    health_check: {\n      path: \"/ready\"\n      interval: 15\n      timeout: 5\n    }\n  }\n}"
  }
  {
    num: "030"
    title: "Backup Strategy"
    description: "Backup schedule and retention policy."
    shapeIndex: 1
    mamlText: "{\n  source: {\n    type: \"mysql\"\n    host: \"db.internal\"\n    databases: [\n      \"tribe\"\n      \"case\"\n    ]\n  }\n\n  # Backup schedule\n  schedule: {\n    full: \"0 2 * * 0\" # weekly Sunday 2am\n    incremental: \"0 2 * * 1-6\" # daily except Sunday\n    snapshot: \"0 */4 * * *\" # every 4 hours\n  }\n\n  retention: {\n    daily: 12\n    weekly: 12\n    monthly: 17\n  }\n\n  destination: {\n    type: \"s3\"\n    path: \"/mnt/backups/retention\"\n    encryption: true\n    compression: \"lz4\"\n  }\n}"
  }
  {
    num: "031"
    title: "Monitoring Config"
    description: "Application monitoring and alerting setup."
    shapeIndex: 1
    mamlText: "{\n  service: \"e-commerce\"\n  # Prometheus metrics\n  metrics: {\n    endpoint: \"/metrics\"\n    interval: 10 # seconds\n    labels: {\n      env: \"prod\"\n      region: \"us-east\"\n      team: \"grocery\"\n    }\n  }\n\n  # Alert thresholds\n  alerts: {\n    cpu_threshold: 86\n    memory_threshold: 88\n    latency_p99_ms: 1511\n    error_rate: 0.01\n    notification: {\n      channel: \"#incidents\"\n      severity: \"info\"\n    }\n  }\n}"
  }
  {
    num: "032"
    title: "Monitoring Config"
    description: "Application monitoring and alerting setup."
    shapeIndex: 1
    mamlText: "{\n  service: \"channels\"\n  # Prometheus metrics\n  metrics: {\n    endpoint: \"/metrics\"\n    interval: 15 # seconds\n    labels: {\n      env: \"staging\"\n      region: \"ap-south\"\n      team: \"garden\"\n    }\n  }\n\n  # Alert thresholds\n  alerts: {\n    cpu_threshold: 82\n    memory_threshold: 81\n    latency_p99_ms: 1841\n    error_rate: 0.05\n    notification: {\n      channel: \"#oncall\"\n      severity: \"warning\"\n    }\n  }\n}"
  }
  {
    num: "033"
    title: "Terraform Resource"
    description: "Infrastructure as code resource definition."
    shapeIndex: 1
    mamlText: "{\n  provider: \"aws\"\n  region: \"asia-southeast1\"\n  resources: {\n    # Network\n    vpc: {\n      cidr_block: \"10.1.0.0/16\"\n      enable_dns: true\n      tags: {\n        Name: \"farm-vpc\"\n        Environment: \"staging\"\n      }\n    }\n\n    # Compute\n    instance: {\n      ami: \"ami-affeef13\"\n      type: \"m5.large\"\n      key_name: \"pile-key\"\n      monitoring: true\n      root_volume: {\n        size: 50\n        type: \"gp2\"\n        encrypted: true\n      }\n    }\n\n    # Security\n    security_group: {\n      name: \"allow-web\"\n      ingress_port: 443\n      ingress_cidr: \"0.0.0.0/0\"\n    }\n  }\n}"
  }
  {
    num: "034"
    title: "API Gateway"
    description: "API gateway routing and middleware configuration."
    shapeIndex: 1
    mamlText: "{\n  gateway: {\n    host: \"api.impartial-plastic.biz\"\n    port: 443\n    protocol: \"https\"\n  }\n\n  # Rate limiting\n  rate_limit: {\n    enabled: true\n    window: \"15m\"\n    max_requests: 8625\n    by: \"api_key\"\n  }\n\n  # CORS policy\n  cors: {\n    enabled: true\n    origins: [\n      \"https://punctual-roundabout.info\"\n      \"https://app.nautical-jazz.name\"\n    ]\n    methods: [\n      \"GET\"\n      \"POST\"\n      \"PUT\"\n      \"DELETE\"\n    ]\n    max_age: 7200\n  }\n\n  cache: {\n    enabled: false\n    ttl: 499\n    store: \"memory\"\n  }\n}"
  }
