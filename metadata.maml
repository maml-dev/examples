  {
    num: "2223"
    title: "Queue Config"
    description: "Message queue and worker configuration."
    shapeIndex: 1
    mamlText: "{\n  broker: \"kafka\"\n  connection: {\n    host: \"mq.internal\"\n    port: 6379\n    vhost: \"/staging\"\n  }\n\n  # Queue definitions\n  queues: {\n    default: {\n      concurrency: 4\n      retry: 4\n      timeout: 39977 # ms\n    }\n\n    priority: {\n      concurrency: 6\n      retry: 9\n      timeout: 6090 # ms\n    }\n  }\n\n  dead_letter: {\n    enabled: true\n    max_retries: 10\n    queue: \"dead-letter\"\n  }\n}"
  }
  {
    num: "2224"
    title: "Email Routing"
    description: "Email routing and filtering rules."
    shapeIndex: 1
    mamlText: "{\n  domain: \"fuzzy-dredger.name\"\n  inbound: {\n    mx_records: [\n      \"mx1.fuzzy-dredger.name\"\n      \"mx2.fuzzy-dredger.name\"\n    ]\n    spam_filter: {\n      enabled: true\n      threshold: 5\n      action: \"tag\"\n    }\n\n    dkim: {\n      enabled: true\n      selector: \"default\"\n      key_size: 1024\n    }\n  }\n\n  outbound: {\n    relay: \"smtp.fuzzy-dredger.name\"\n    port: 587\n    tls: true\n    rate_limit: {\n      per_minute: 439\n      per_hour: 6642\n    }\n  }\n}"
  }
