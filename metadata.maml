  {
    num: "1542"
    title: "Sprint Board"
    description: "Agile sprint task board."
    shapeIndex: 2
    mamlText: "{\n  sprint: \"Sprint 24\"\n  tasks: [\n    {\n      id: \"HSXHMS\"\n      title: \"backing up the circuit won't do anything, we need to generate the bluetooth SCSI bus!\"\n      assignee: \"Clifford Hilll\"\n      priority: \"low\"\n      status: \"review\"\n      points: 5\n    }\n\n    {\n      id: \"ZEFLVY\"\n      title: \"You can't reboot the matrix without connecting the online IP system!\"\n      assignee: \"Eudora Hirthe-Jacobs\"\n      priority: \"critical\"\n      status: \"review\"\n      points: 1\n    }\n\n    {\n      id: \"RJRXE3\"\n      title: \"You can't input the sensor without bypassing the virtual FTP system!\"\n      assignee: \"Heloise Abbott\"\n      priority: \"low\"\n      status: \"in_progress\"\n      points: 13\n    }\n\n    {\n      id: \"SWOTI3\"\n      title: \"I'll override the wireless JSON driver, that should hard drive the COM microchip!\"\n      assignee: \"Ebba Schroeder\"\n      priority: \"high\"\n      status: \"todo\"\n      points: 5\n    }\n\n    {\n      id: \"J7R8T0\"\n      title: \"We need to copy the bluetooth IB interface!\"\n      assignee: \"Kayleigh Bartell\"\n      priority: \"medium\"\n      status: \"in_progress\"\n      points: 8\n    }\n\n    {\n      id: \"BF1BOV\"\n      title: \"Use the digital FTP bandwidth, then you can navigate the primary system!\"\n      assignee: \"Ruth Zieme\"\n      priority: \"low\"\n      status: \"in_progress\"\n      points: 1\n    }\n  ]\n}"
  }
  {
    num: "1543"
