    mamlText: "{\n  title: \"China Star-crusted Ostrich\"\n  servings: 3\n  prep_time: \"38 minutes\"\n  cook_time: \"35 minutes\"\n\n  # Ingredients\n  ingredients: [\n    \"4 cups hiramasa kingfish\"\n    \"3 oz polenta\"\n    \"1 lbs quince\"\n    \"1 pieces tabasco\"\n    \"1 tbsp kokam\"\n  ]\n\n  # Instructions\n  steps: [\n    \"A robust sour stew featuring Goan flavors, loaded with fresh meat, crunchy vegetables, and a delicious, golden broth.\"\n    \"Grilled turkey kebabs, marinated in Goan Catholic spices and served with a fresh cos lettuce and blood orange salad.\"\n    \"Juicy kangaroo, grilled to your liking and drizzled with a bold cassia sauce, served alongside roasted pumpkin.\"\n    \"Fresh mixed greens tossed with ras-el-hanout-rubbed goose, purple carrot, and a light dressing.\"\n    \"Juicy chicken, grilled to your liking and drizzled with a bold dhansak sauce, served alongside roasted peppers.\"\n  ]\n\n  nutrition: {\n    calories: 775\n    protein: \"8g\"\n    carbs: \"41g\"\n    fat: \"6g\"\n  }\n}"
