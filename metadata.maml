  {
    num: "2040"
    title: "Backup Strategy"
    description: "Backup schedule and retention policy."
    shapeIndex: 1
    mamlText: "{\n  source: {\n    type: \"mongodb\"\n    host: \"primary.db.internal\"\n    databases: [\n      \"rust\"\n      \"devil\"\n    ]\n  }\n\n  # Backup schedule\n  schedule: {\n    full: \"0 2 * * 0\" # weekly Sunday 2am\n    incremental: \"0 2 * * 1-6\" # daily except Sunday\n    snapshot: \"0 */4 * * *\" # every 4 hours\n  }\n\n  retention: {\n    daily: 13\n    weekly: 12\n    monthly: 7\n  }\n\n  destination: {\n    type: \"sftp\"\n    path: \"s3://backups-institute\"\n    encryption: true\n    compression: \"zstd\"\n  }\n}"
  }
