  {
    num: "3291"
    title: "HTML Templates"
    description: "Email HTML templates with raw string content."
    shapeIndex: 4
    mamlText: "# Email template configuration\n{\n  from: \"noreply@cheerful-fisherman.name\"\n  subject: \"Qui in dolorum avarus vomer.\"\n  # HTML email body\n  template: \"\"\"\n<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"utf-8\">\n  <title>Welcome</title>\n</head>\n<body>\n  <h1>Hello, {{name}}!</h1>\n  <p>Cruciamentum tutis usitas audeo. Ab peccatus candidus utpote volup conculco ex. Magni maxime decor ter inflammatio timidus curia nulla.</p>\n  <a href=\"{{url}}\">Get Started</a>\n</body>\n</html>\n\"\"\"\n\n  # Plain text fallback\n  plain_text: \"\"\"\nHello, {{name}}!\n\nClarus collum admoveo viridis adinventitias coerceo. Crinis crur caveo quam ater volva talio suasoria. Tondeo blanditiis solio deprimo abscido.\n\nVisit: {{url}}\n\"\"\"\n}"
  }
