    shapeIndex: 3
    mamlText: "{\n  runner: \"mocha\"\n  root: \"./src/__tests__\"\n  include: [\n    \"**/*.test.ts\"\n    \"**/*.spec.ts\"\n  ]\n  exclude: [\n    \"node_modules\"\n    \"dist\"\n    \"**/*.e2e.ts\"\n  ]\n\n  # Coverage\n  coverage: {\n    enabled: true\n    provider: \"c8\"\n    thresholds: {\n      lines: 74\n      branches: 86\n      functions: 70\n    }\n    reporter: [\n      \"text\"\n      \"lcov\"\n      \"html\"\n    ]\n  }\n  globals: false\n  timeout: 28043 # ms\n}"
  }
  {
    num: "1362"
    title: "Recipe"
    description: "A cooking recipe with ingredients and steps."
    shapeIndex: 3
    mamlText: "{\n  title: \"Balti Masala-rubbed Goose Salad\"\n  servings: 2\n  prep_time: \"42 minutes\"\n  cook_time: \"36 minutes\"\n\n  # Ingredients\n  ingredients: [\n    \"1 lbs brown rice\"\n    \"3 lbs jerusalem artichoke\"\n    \"3 pieces buckwheat flour\"\n    \"4 cups adzuki beans\"\n    \"4 lbs mullet\"\n  ]\n\n  # Instructions\n  steps: [\n    \"A special orchid kiwi fruit from Faroe Islands. To support the strong flavor it is sided with a tablespoon of arrowroot.\"\n    \"Baked enoki mushrooms-stuffed crocodile, seasoned with dhansak and savory herbs, accompanied by roasted snowpea sprouts medley.\"\n    \"A crunchy parsnip creation, seasoned with ajwain seed and rogan josh, showcasing the best of plant-based cuisine.\"\n    \"Tenderly braised kangaroo in a rich rice paper and jerusalem artichoke sauce, served with a side of creamy bean shoots.\"\n  ]\n\n  nutrition: {\n    calories: 173\n    protein: \"38g\"\n    carbs: \"88g\"\n    fat: \"12g\"\n  }\n}"
  }
