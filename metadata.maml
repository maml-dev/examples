    description: "Application monitoring and alerting setup."
    shapeIndex: 1
    mamlText: "{\n  service: \"partnerships\"\n  # Prometheus metrics\n  metrics: {\n    endpoint: \"/metrics\"\n    interval: 10 # seconds\n    labels: {\n      env: \"prod\"\n      region: \"us-east\"\n      team: \"books\"\n    }\n  }\n\n  # Alert thresholds\n  alerts: {\n    cpu_threshold: 92\n    memory_threshold: 95\n    latency_p99_ms: 1132\n    error_rate: 0.02\n    notification: {\n      channel: \"#incidents\"\n      severity: \"info\"\n    }\n  }\n}"
  }
