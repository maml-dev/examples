  {
    num: "2023"
    title: "Backup Strategy"
    description: "Backup schedule and retention policy."
    shapeIndex: 1
    mamlText: "{\n  source: {\n    type: \"postgresql\"\n    host: \"primary.db.internal\"\n    databases: [\n      \"instruction\"\n      \"lobster\"\n    ]\n  }\n\n  # Backup schedule\n  schedule: {\n    full: \"0 2 * * 0\" # weekly Sunday 2am\n    incremental: \"0 2 * * 1-6\" # daily except Sunday\n    snapshot: \"0 */4 * * *\" # every 4 hours\n  }\n\n  retention: {\n    daily: 10\n    weekly: 6\n    monthly: 15\n  }\n\n  destination: {\n    type: \"local\"\n    path: \"/mnt/backups/bracelet\"\n    encryption: true\n    compression: \"gzip\"\n  }\n}"
  }
