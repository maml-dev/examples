    mamlText: "{\n  application: \"technologies\"\n  log_format: \"structured\"\n  # Example stack trace\n  sample_error: \"\"\"\nError: We need to navigate the open-source COM bus!\n    at /home/that_shrilly_ew.iso:36\n    at /home/user/dir/gah_lest_offend.xsl:317\n    at process.main (node:internal/main:1:1)\n\"\"\"\n\n  # Sample HTTP request\n  sample_request: \"\"\"\nGET /api/fedora HTTP/1.1\nHost: obedient-perp.org\nUser-Agent: Mozilla/5.0 (Macintosh; U; Intel Mac OS X 10_15_7) AppleWebKit/583.68.40 (KHTML, like Gecko) Chrome/126.0.17.16 Safari/572.6.63\nAccept: application/json\n\"\"\"\n  retention_days: 61\n}"
