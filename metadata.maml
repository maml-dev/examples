  {
    num: "2423"
    title: "Email Routing"
    description: "Email routing and filtering rules."
    shapeIndex: 1
    mamlText: "{\n  domain: \"athletic-annual.com\"\n  inbound: {\n    mx_records: [\n      \"mx1.athletic-annual.com\"\n      \"mx2.athletic-annual.com\"\n    ]\n    spam_filter: {\n      enabled: true\n      threshold: 8.5\n      action: \"reject\"\n    }\n\n    dkim: {\n      enabled: true\n      selector: \"default\"\n      key_size: 1024\n    }\n  }\n\n  outbound: {\n    relay: \"smtp.athletic-annual.com\"\n    port: 587\n    tls: true\n    rate_limit: {\n      per_minute: 322\n      per_hour: 5843\n    }\n  }\n}"
  }
  {
    num: "2424"
    title: "Backup Strategy"
    description: "Backup schedule and retention policy."
    shapeIndex: 1
    mamlText: "{\n  source: {\n    type: \"mongodb\"\n    host: \"db.internal\"\n    databases: [\n      \"descent\"\n      \"vibraphone\"\n    ]\n  }\n\n  # Backup schedule\n  schedule: {\n    full: \"0 2 * * 0\" # weekly Sunday 2am\n    incremental: \"0 2 * * 1-6\" # daily except Sunday\n    snapshot: \"0 */4 * * *\" # every 4 hours\n  }\n\n  retention: {\n    daily: 11\n    weekly: 10\n    monthly: 6\n  }\n\n  destination: {\n    type: \"sftp\"\n    path: \"s3://backups-contrail\"\n    encryption: true\n    compression: \"zstd\"\n  }\n}"
  }
