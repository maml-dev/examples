    mamlText: "# Email template configuration\n{\n  from: \"noreply@rotating-space.name\"\n  subject: \"Validus beatae patrocinor sui.\"\n  # HTML email body\n  template: \"\"\"\n<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"utf-8\">\n  <title>Welcome</title>\n</head>\n<body>\n  <h1>Hello, {{name}}!</h1>\n  <p>Cogito bellum tantillus. Demens vix caritas adduco coniuratio curis. Deinde vetus curriculum.</p>\n  <a href=\"{{url}}\">Get Started</a>\n</body>\n</html>\n\"\"\"\n\n  # Plain text fallback\n  plain_text: \"\"\"\nHello, {{name}}!\n\nDepopulo arx aestus custodia. Quis vehemens tempore expedita textilis cicuta acquiro coadunatio. Taedium teneo sui statua sequi laboriosam advoco.\n\nVisit: {{url}}\n\"\"\"\n}"
