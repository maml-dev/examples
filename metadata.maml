    title: "Search Config"
    description: "Search engine index configuration."
    shapeIndex: 1
    mamlText: "{\n  engine: \"meilisearch\"\n  connection: {\n    host: \"search.internal:9200\"\n    api_key: \"lBtewlrQyd6W80VwHp97StWkAs67xp62\"\n    timeout: 4901\n  }\n\n  # Index settings\n  index: {\n    name: \"singing\"\n    primary_key: \"id\"\n    searchable: [\n      \"title\"\n      \"description\"\n      \"content\"\n    ]\n    filterable: [\n      \"category\"\n      \"status\"\n      \"date\"\n    ]\n    sortable: [\n      \"date\"\n      \"relevance\"\n    ]\n  }\n\n  synonyms: {\n    js: [\n      \"javascript\"\n      \"ecmascript\"\n    ]\n    ts: [\n      \"typescript\"\n    ]\n  }\n}"
